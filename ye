local function findWinnerPad()
	local wp = Players:FindFirstChild(winner)
	if not wp or not wp.Character then return nil end
	local wr = wp.Character:FindFirstChild("HumanoidRootPart")
	if not wr then return nil end
	local boxes = workspace:FindFirstChild("Ignored")
	if not boxes then return nil end
	local b = boxes:FindFirstChild("Boxes")
	if not b then return nil end
	for _, fp in ipairs(b:GetChildren()) do
		if fp.Name ~= "FightPlace" then continue end
		local j1 = fp:FindFirstChild("JoinFight1")
		if not j1 then continue end
		local r1 = j1:FindFirstChild("Region")
		if not r1 then continue end
		if (wr.Position - r1.Position).Magnitude < 20 then
			return fp
		end
	end
	return nil
end

local function startPadLoop()
	if padded then return end
	padded = true
	task.spawn(function()
		activeFp = nil
		local r1, r2 = nil, nil

		while not inBox and not paused and running do
			if amWinner then
				if not activeFp or not isPadAreaClear(activeFp) then
					local newFp = findEmptyFightPlace()
					if newFp then
						activeFp = newFp
						local id = tostring(activeFp:GetDebugId())
						activeFp:SetAttribute("_padId", id)
						sharedPadId = id
						r1, r2 = getPads(activeFp)
						
						tp(r1.CFrame + Vector3.new(0, 3, 0))
						local er = getEnemyRoot()
						if er then 
							er.CFrame = r2.CFrame + Vector3.new(0, 3, 0) 
						end
						
						task.wait(1.0)
					else
						if not activeFp then
							r1, r2 = nil, nil
						end
					end
				end

				if r1 and r2 then
					if isPadAreaClear(activeFp) then
						tp(r1.CFrame + Vector3.new(0, 3, 0))
						local er = getEnemyRoot()
						if er then er.CFrame = r2.CFrame + Vector3.new(0, 3, 0) end
					else
						tp(r1.CFrame + Vector3.new(0, 10, 0))
						local er = getEnemyRoot()
						if er then er.CFrame = r2.CFrame + Vector3.new(0, 10, 0) end
					end
				end
			elseif amLoser then
				local fp = findWinnerPad()
				if fp then
					local _, lr2 = getPads(fp)
					if lr2 then
						if isPadAreaClear(fp) then
							tp(lr2.CFrame + Vector3.new(0, 3, 0))
						else
							tp(lr2.CFrame + Vector3.new(0, 10, 0))
						end
					end
				end
			end

			task.wait(0.1)
		end

		padded = false
	end)
end

local function selfDestruct()
	running = false
	paused = true
	for _, cn in ipairs(cons) do
		if cn then
			cn:Disconnect()
		end
	end
	inBox = false
	padded = false
	local oldPlate = workspace:FindFirstChild("_skyPlate")
	if oldPlate then
		oldPlate:Destroy()
	end
end

local inputCn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == stopKey then
		selfDestruct()
	end
end)
registerConnection(inputCn)

local function getWinstreak()
	local wp = Players:FindFirstChild(winner)
	if wp then
		local df = wp:FindFirstChild("DataFolder")
		local info = df and df:FindFirstChild("Information")
		local wsData = info and info:FindFirstChild("WinstreakData")
		local curWS = wsData and wsData:FindFirstChild("CurrentWinstreak")
		if curWS then
			return curWS.Value
		end
	end
	return 0
end

local function getCoins()
	local wp = Players:FindFirstChild(winner)
	if wp then
		local df = wp:FindFirstChild("DataFolder")
		local info = df and df:FindFirstChild("Information")
		local currency = info and info:FindFirstChild("Currency")
		if currency then
			return currency.Value
		end
	end
	return 0
end

local function getUptimeString()
	local elapsed = tick() - startTime
	local hours = math.floor(elapsed / 3600)
	local minutes = math.floor((elapsed % 3600) / 60)
	local seconds = math.floor(elapsed % 60)
	return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

local function sendWebhook(streak)
	if not webhookUrl or webhookUrl == "" or webhookUrl:find("YOUR_DISCORD") then return end
	if not request then return end
	
	local current = streak or getWinstreak()
	highestWinstreak = math.max(highestWinstreak, current)
	local gained = startingWinstreak and (current - startingWinstreak) or 0
	if gained < 0 then gained = 0 end
	
	local payload = {
		["username"] = "AutoFarm Tracker",
		["embeds"] = {{
			["title"] = "Match " .. tostring(matchCount) .. " Done",
			["color"] = 2067276,
			["fields"] = {
				{ ["name"] = "Method", ["value"] = selectedGun .. " Method", ["inline"] = true },
				{ ["name"] = "Winner", ["value"] = winner, ["inline"] = true },
				{ ["name"] = "Match", ["value"] = tostring(matchCount), ["inline"] = true },
				
				{ ["name"] = "Current Winstreak", ["value"] = tostring(current), ["inline"] = true },
				{ ["name"] = "Highest Winstreak", ["value"] = tostring(highestWinstreak), ["inline"] = true },
				{ ["name"] = "Coins", ["value"] = tostring(getCoins()), ["inline"] = true },
				
				{ ["name"] = "Match Duration", ["value"] = lastMatchDuration, ["inline"] = true },
				{ ["name"] = "Farm Uptime", ["value"] = getUptimeString(), ["inline"] = true },
				{ ["name"] = "Streak Gained Session", ["value"] = tostring(gained), ["inline"] = true },
				
				{ ["name"] = "Streak Goal", ["value"] = tostring(current) .. " / " .. tostring(maxWinstreak), ["inline"] = false }
			},
			["footer"] = {
				["text"] = "AutoFarm"
			},
			["timestamp"] = DateTime.now():ToIsoDate()
		}}
	}
	
	pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
end

task.spawn(function()
	task.wait(5)
	startingWinstreak = getWinstreak()
	highestWinstreak = startingWinstreak
end)

task.spawn(function()
	local lastWebhookTime = 0
	while running do
		task.wait(1)
		local currentStreak = getWinstreak()
		
		if currentStreak >= maxWinstreak then
			pcall(function()
				sendWebhook(currentStreak)
			end)
			selfDestruct()
			break
		end
		
		if tick() - lastWebhookTime >= webhookInterval then
			sendWebhook(currentStreak)
			lastWebhookTime = tick()
		end
	end
end)

local lastInvalidTime = 0
local skyPos = nil

task.spawn(function()
	while running do
		RunService.Heartbeat:Wait()

		if not char or not root then getChar() continue end
		if hum.Health <= 0 then task.wait(0.5) continue end

		if inBoxCheck() then
			local gunName = getGunName()
			if not inBox then
				inBox = true
				padded = false
				lastInvalidTime = tick()
				roundStartTime = tick()
				if amWinner then
					task.wait(0.1)
					grabGun()
				end

				task.wait(0.2)
				if amWinner and root then
					skyPos = root.Position + Vector3.new(0, 500, 0)
					createPlatform(skyPos)
				end
			end

			if amWinner then
				if skyPos then
					local plat = workspace:FindFirstChild("_skyPlate")
					if not plat then createPlatform(skyPos) end
					if root then
						tp(CFrame.new(skyPos + Vector3.new(-3, 1, 0)))
					end
				end
			elseif amLoser then
				local wp = Players:FindFirstChild(winner)
				local wChar = wp and wp.Character
				local wRoot = wChar and wChar:FindFirstChild("HumanoidRootPart")
				
				if wRoot and wRoot.Position.Y > 300 then
					local targetPos = wRoot.Position + Vector3.new(6, 0, 0)
					local plat = workspace:FindFirstChild("_skyPlate")
					if not plat then 
						createPlatform(wRoot.Position + Vector3.new(3, 0, 0)) 
					end
					if root then
						tp(CFrame.new(targetPos))
					end
				end
			end

			if amWinner then
				local enemyPlayer = Players:FindFirstChild(loser)
				if enemyPlayer and enemyPlayer.Character then
					local enemyHum = enemyPlayer.Character:FindFirstChildOfClass("Humanoid")
					local enemyRoot = enemyPlayer.Character:FindFirstChild("HumanoidRootPart")
					local hasFF = enemyPlayer.Character:FindFirstChildOfClass("ForceField")
					local isKO = false
					local be = enemyPlayer.Character:FindFirstChild("BodyEffects")
					if be and be:FindFirstChild("K.O") and be["K.O"].Value then
						isKO = true
					end

					if not char:FindFirstChild(gunName) then
						grabGun()
						task.wait(0.2)
					end

					if hasFF or not enemyHum or enemyHum.Health <= 0 or isKO then
						lastInvalidTime = tick()
					else
						local currentDelay = selectedGun == "Revolver" and 0 or 2
						if tick() - lastInvalidTime >= currentDelay then
							if getgenv().FH_Fire then
								getgenv().FH_Fire(enemyPlayer)
							end
							lastInvalidTime = tick()
						end
					end
				end
				task.wait(0.05)
			end
			continue
		end

		if inBox then
			inBox = false
			padded = false
			sharedPadId = nil
			skyPos = nil
			
			local plat = workspace:FindFirstChild("_skyPlate")
			if plat then
				plat:Destroy()
			end

			matchCount = matchCount + 1
			if roundStartTime then
				lastMatchDuration = tostring(math.floor(tick() - roundStartTime)) .. "s"
			end

			task.spawn(function()
				task.wait(1.5)
				local current = getWinstreak()
				sendWebhook(current)
			end)

			if paused then task.wait(1) continue end
		end

		if paused then task.wait(1) continue end

		if not padded and bothInCharacters() then
			startPadLoop()
		end

		task.wait(0.3)
	end
end)
