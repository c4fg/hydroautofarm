local function getPads(fp)
	local j1 = fp:FindFirstChild("JoinFight1")
	local j2 = fp:FindFirstChild("JoinFight2")
	if not j1 or not j2 then return nil, nil end
	return j1:FindFirstChild("Region"), j2:FindFirstChild("Region")
end

local function isPadAreaClear(fp)
	if not fp then return false end
	local r1, r2 = getPads(fp)
	if not r1 or not r2 then return false end

	for _, p in ipairs(Players:GetPlayers()) do
		if p.Name ~= winner and p.Name ~= loser then
			local pChar = p.Character
			local pRoot = pChar and pChar:FindFirstChild("HumanoidRootPart")
			if pRoot then
				local distToR1 = (pRoot.Position - r1.Position).Magnitude
				local distToR2 = (pRoot.Position - r2.Position).Magnitude
				if distToR1 < 15 or distToR2 < 15 then
					return false
				end
			end
		end
	end

	return true
end

local function findEmptyFightPlace()
	local boxes = workspace:FindFirstChild("Ignored")
	if not boxes then return nil end
	local b = boxes:FindFirstChild("Boxes")
	if not b then return nil end
	for _, fp in ipairs(b:GetChildren()) do
		if fp.Name ~= "FightPlace" then continue end
		if activeFp and fp == activeFp then continue end

		local p1 = fp:FindFirstChild("Player1")
		local p2 = fp:FindFirstChild("Player2")
		if not p1 or not p2 then continue end
		local v1 = p1.Value
		local v2 = p2.Value
		if (v1 == "" or v1 == nil) and (v2 == "" or v2 == nil) then
			if isPadAreaClear(fp) then
				return fp
			end
		end
	end
	return nil
end

local function bothInCharacters()
	local folder = workspace:FindFirstChild("Players")
	if not folder then return false end
	local chars = folder:FindFirstChild("Characters")
	if not chars then return false end
	return chars:FindFirstChild(winner) ~= nil and chars:FindFirstChild(loser) ~= nil
end

local function inBoxCheck()
	local f = workspace:FindFirstChild("Players")
	if not f then return false end
	local ib = f:FindFirstChild("InBox")
	if not ib then return false end
	return ib:FindFirstChild(lp.Name) ~= nil
end

local function getEnemyRoot()
	local p = Players:FindFirstChild(loser)
	if not p or not p.Character then return nil end
	return p.Character:FindFirstChild("HumanoidRootPart")
end

local function getGunName()
	return selectedGun == "Revolver" and "[Revolver]" or "[DoubleBarrel]"
end

local function grabGun()
	local gunName = getGunName()
	local bp = lp:FindFirstChild("Backpack")
	if bp then
		local g = bp:FindFirstChild(gunName)
		if g then hum:EquipTool(g) task.wait(0.2) return true end
	end
	return char:FindFirstChild(gunName) ~= nil
end

local function createPlatform(pos)
	local p = workspace:FindFirstChild("_skyPlate")
	if not p then
		p = Instance.new("Part")
		p.Name = "_skyPlate"
		p.Size = Vector3.new(20, 1, 20)
		p.Position = pos - Vector3.new(0, 3.5, 0)
		p.Anchored = true
		p.CanCollide = true
		p.Transparency = 0.5
		p.Material = Enum.Material.SmoothPlastic
		p.Parent = workspace
	end
	return p
end

local amWinner = lp.Name == winner
local amLoser  = lp.Name == loser

local request = (syn and syn.request) or (http and http.request) or request or http_request

local function isStaff(player)
	for _, val in ipairs(CustomStaff) do
		if typeof(val) == "string" and player.Name:lower() == val:lower() then
			return true
		elseif typeof(val) == "number" and player.UserId == val then
			return true
		end
	end

	local ok, result = pcall(function()
		return player:IsInGroup(Staff)
	end)
	return ok and result
end

local function sendStaffAlert(staffPlayer)
	if not webhookUrl or webhookUrl == "" or webhookUrl:find("YOUR_DISCORD") then return end
	if not request then return end
	
	local content = alertEveryoneOnStaffJoin and "@everyone" or ""
	local payload = {
		["username"] = "Staff Alert System",
		["content"] = content,
		["embeds"] = {{
			["title"] = "⚠️ Staff Detected - Autofarm Paused!",
			["description"] = "An authorized staff member or custom listed player has joined the server.\n\n" ..
			                  "**Username:** " .. staffPlayer.Name .. "\n" ..
			                  "**User ID:** " .. tostring(staffPlayer.UserId) .. "\n" ..
			                  "**Profile Link:** [Roblox Profile](https://www.roblox.com/users/" .. tostring(staffPlayer.UserId) .. "/profile)",
			["color"] = 16711680,
			["timestamp"] = DateTime.now():ToIsoDate()
		}}
	}
	
	pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
end

local function stopFarm()
	paused = true
	inBox = false
	padded = false
	sharedPadId = nil
end

local function resumeFarm()
	paused = false
	padded = false
end

for _, p in ipairs(Players:GetPlayers()) do
	if p ~= lp and isStaff(p) then 
		sendStaffAlert(p)
		stopFarm() 
	end
end

